# Beispiel-Konfiguration für lokale Entwicklung.
# Kopiere diese Datei nach `.env` und trage echte Werte ein.
# `.env` ist git-ignoriert und darf NIEMALS committet werden.

# === EU-Modelle (DSGVO-konform) ===
ALEPH_ALPHA_API_KEY=
ALEPH_ALPHA_API_BASE=https://inference-api.your-alephalpha.com
MISTRAL_API_KEY=
IONOS_AI_API_KEY=
IONOS_AI_BASE_URL=https://openai.inference.de-txl.ionos.com/v1

# === US-Modelle (mit AVV + EU-Region wo möglich) ===
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1
ANTHROPIC_API_KEY=
GOOGLE_API_KEY=

# === Drittanbieter-Hoster (für Open-Weight-Modelle) ===
TOGETHER_API_KEY=
FIREWORKS_API_KEY=
DEEPINFRA_API_KEY=
SCALEWAY_AI_API_KEY=

# === Asiatische Anbieter — VORSICHT: offizielle CN-API ist DSGVO-problematisch ===
# Nur für Lehrzwecke / Self-Censorship-Audit nutzen, NIEMALS mit personenbezogenen Daten.
DEEPSEEK_API_KEY=
DASHSCOPE_API_KEY=
MOONSHOT_API_KEY=
ZHIPU_API_KEY=

# === Vector DB ===
QDRANT_URL=http://localhost:6333
QDRANT_API_KEY=

# === Observability (EU-self-hosted bevorzugen) ===
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_HOST=https://cloud.langfuse.com
PHOENIX_PROJECT_NAME=ki-engineering-werkstatt

# === Hugging Face (für Datasets/Modelle) ===
HF_TOKEN=

# === Diverse ===
LOG_LEVEL=INFO
