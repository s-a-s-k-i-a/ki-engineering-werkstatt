root = true

[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true
indent_style = space

[*.py]
indent_size = 4
max_line_length = 100

[*.{md,markdown}]
indent_size = 2
trim_trailing_whitespace = false

[*.{yml,yaml,json,toml}]
indent_size = 2

[Makefile]
indent_style = tab

[justfile]
indent_size = 4
