# Beispiel-Konfiguration für den KI-Plugin-Helfer-Sidecar.
# Kopiere zu .env (in .gitignore) und passe an.

# ─── Qdrant ─────────────────────────────────────────────────────────
QDRANT_URL=http://qdrant:6333

# ─── LLM-Backend ────────────────────────────────────────────────────
# Optionen: stub (kein LLM), ollama (lokal), vllm (lokal/Cloud), openai (mit AVV)
LLM_BACKEND=ollama
LLM_BASE_URL=http://ollama:11434
LLM_MODEL=llama3.3:8b
# LLM_API_KEY=  (nur bei OpenAI-kompatibler API)

# ─── Plugin-Repos ───────────────────────────────────────────────────
# Mount-Pfad innerhalb des Containers, wo deine Plugin-Quellen liegen
PLUGIN_REPO_PATH=/data/plugins

# ─── DSGVO ──────────────────────────────────────────────────────────
# Optional: API-Key, der vom Plugin als Bearer-Token gesendet werden muss
# SIDECAR_API_KEY=
